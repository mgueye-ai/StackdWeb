# Copy to .env.local for local `vercel dev`, then set the same vars in Vercel → Project → Settings → Environment Variables.

# Site URL (production — use your live domain)
SITE_URL=https://toostackd.com

# Resend — primary email list (https://resend.com)
# IMPORTANT: Use a Full access API key (NOT "Sending access" only) so contacts can be added to your Waitlist segment.
RESEND_API_KEY=re_your_full_access_api_key
RESEND_SEGMENT_ID=your-waitlist-segment-id
RESEND_FROM=Stackd <hello@toostackd.com>

# Supabase — waitlist backup + order storage
# IMPORTANT: Use service_role secret — NOT the anon/public key.
SUPABASE_URL=https://jlwtcmauxcauscriagey.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — checkout (https://dashboard.stripe.com)
# Test keys start with sk_test_ / whsec_ — use live keys in production
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional: Stripe Price IDs (create products in Stripe Dashboard → Products)
# If not set, checkout uses inline prices ($49 / $99)
# STRIPE_PRICE_STACKD=price_xxx
# STRIPE_PRICE_STACKD_UP=price_xxx
